{
  "name": "forwebmotion-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "intlayer watch --with 'next dev'",
    "build": "intlayer build && next build",
    "analyze": "pnpm next experimental-analyze",
    "check-install-scripts": "npx can-i-ignore-scripts",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mdx --fix",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx,.mdx",
    "format": "prettier \"**/*.+(ts|tsx|js|jsx|mdx|md|json|css)\" --write",
    "format:check": "prettier \"**/*.+(ts|tsx|js|jsx|mdx|md|json|css)\" --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@tabler/icons-react": "3.45.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "intlayer": "8.12.4",
    "next": "16.2.10",
    "next-intlayer": "8.12.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "4.13.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint-react/eslint-plugin": "5.17.3",
    "@intlayer/swc": "8.12.4",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3"
  }
